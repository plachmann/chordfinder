{
  "expo": {
    "name": "ChordFinder",
    "slug": "chordfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1410"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chordfinder.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ChordFinder needs microphone access to listen to music and detect chord progressions in real time."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1410"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.chordfinder.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
